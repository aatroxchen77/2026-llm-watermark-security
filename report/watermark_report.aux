\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces 高熵场景与低熵场景的水印可靠性对比。高熵 Prompt（创造性写作）的 Z-score 分布更集中且均值更高，而低熵 Prompt（事实陈述）因模型确定性更强，绿名单偏置与语义约束的冲突加剧，导致 Z-score 方差增大。}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:entropy}{{2}{5}{高熵场景与低熵场景的水印可靠性对比。高熵 Prompt（创造性写作）的 Z-score 分布更集中且均值更高，而低熵 Prompt（事实陈述）因模型确定性更强，绿名单偏置与语义约束的冲突加剧，导致 Z-score 方差增大。}{figure.2}{}}
